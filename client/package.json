{
  "name": "bridge-buddy",
  "private": true,
  "version": "0.1.2",
  "type": "module",
  "main": "electron/main.js",
  "description": "League of Legends ARAM stats tracker app",
  "author": "Noah Barnes",
  "scripts": {
    "dev": "vite",
    "electron": "electron .",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "dist": "npm run build && electron-builder",
    "publish": "npm run build && electron-builder --publish always",
    "clean": "powershell -Command \"Remove-Item -Recurse -Force dist -ErrorAction SilentlyContinue\""
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.98.0",
    "axios": "^1.13.5",
    "dotenv": "^17.4.2",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.0"
  },
  "build": {
    "appId": "com.NoahBarnes.bridgebuddy",
    "productName": "Bridge Buddy",
    "files": [
      "dist-vite/**/*",
      "electron/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "Barnesn22",
        "repo": "ARAM-S-Tracker",
        "releaseType": "release"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/favicon.ico"
    },
    "nsis": {
      "installerIcon": "build/favicon.ico",
      "uninstallerIcon": "build/favicon.ico"
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.27",
    "electron": "^40.4.1",
    "electron-builder": "^26.8.1",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.9",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4.2.2",
    "vite": "^7.3.2"
  }
}
